{
  "name": "google-slides-mcp",
  "version": "1.0.0",
  "description": "Google Slides MCP server with Google OAuth (@example.com domain restriction) — read, template-fill, and edit decks",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "test": "tsc && node --test dist/test/*.test.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^5.2.1",
    "googleapis": "^140.0.0",
    "google-auth-library": "^9.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22"
  }
}
